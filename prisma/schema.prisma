// =======================================================
// GENERATOR & DATASOURCE
// =======================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================================================
// ACTIVE MVP: SANDY TOES VILLA BOOKING SYSTEM
// =======================================================
// Goal for this phase:
// - take direct villa bookings
// - prevent unavailable dates from being booked
// - track payment/email/admin status
// - show booking details in admin
//
// Guest login is intentionally skipped for now to keep checkout conversion high.
// Admin login continues to use the User table below.
// =======================================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String   @unique
  passwordHash String?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  isGuest      Boolean  @default(true)

  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  sessionVersion      Int       @default(1)

  villaAdminNotes VillaAdminNote[]
  villaBlocks     VillaBlock[]
  bookingActivities BookingActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

model Villa {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  timezone              String   @default("America/Nassau")
  currency              String   @default("USD")
  baseNightlyRateCents  Int
  cleaningFeeCents      Int      @default(0)
  maxGuests             Int      @default(14)
  bedrooms              Int      @default(4)
  bathrooms             Decimal  @default(4.5) @db.Decimal(3, 1)
  active                Boolean  @default(true)

  bookings     VillaBooking[]
  payments     VillaPayment[]
  blockedDates VillaBlockedDate[]
  adminNotes   VillaAdminNote[]
  emailLogs    VillaEmailLog[]
  locks        VillaBookingLock[]
  blocks       VillaBlock[]
  activityLogs BookingActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model VillaBlock {
  id      String @id @default(cuid())
  villaId String

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  type   VillaBlockType
  reason String?
  source VillaBlockSource @default(ADMIN)

  createdById String?

  villa     Villa @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([villaId, startDate, endDate])
  @@index([type, createdAt])
  @@index([source, createdAt])
  @@index([createdById])
}

model VillaBookingLock {
  id      String @id @default(cuid())
  villaId String

  checkIn  DateTime @db.Date
  checkOut DateTime @db.Date

  adults   Int
  children Int @default(0)

  guestEmail String?
  guestPhone String?

  quoteSnapshot Json?

  lockToken String @unique
  sessionId String

  status VillaBookingLockStatus @default(ACTIVE)
  expiresAt DateTime
  consumedAt DateTime?
  consumedBookingRef String?

  villa Villa @relation(fields: [villaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([villaId])
  @@index([villaId, checkIn, checkOut])
  @@index([expiresAt])
  @@index([status, expiresAt])
  @@index([sessionId])
  @@index([consumedBookingRef])
}

model VillaBooking {
  id         String @id @default(cuid())
  bookingRef String @unique
  villaId    String

  propertySlug String @default("sandy-toes")
  propertyName String @default("Sandy Toes at Treasure Cay")

  checkIn  DateTime @db.Date
  checkOut DateTime @db.Date
  nights   Int

  adults   Int
  children Int @default(0)

  guestFirstName    String
  guestLastName     String
  guestEmail        String
  guestPhoneCountry String
  guestPhone        String

  billingCountry  String
  billingAddress  String
  billingAddress2 String?
  billingCity     String
  billingState    String
  billingZip      String

  paymentMethod String
  cardLast4     String?

  damageOption VillaDamageOption

  nightlyRateCents         Int
  subtotalCents            Int
  damageProtectionFeeCents Int     @default(0)
  totalCents               Int
  currency                 String  @default("USD")
  promoCode                String?

  status        VillaBookingStatus @default(READY_FOR_PAYMENT)
  paymentStatus PaymentStatus      @default(INITIALIZED)

  termsAcceptedAt DateTime?
  expiresAt       DateTime?
  cancelledAt     DateTime?
  cancelledReason String?

  payments  VillaPayment[]
  notes     VillaAdminNote[]
  emailLogs VillaEmailLog[]
  activities BookingActivityLog[]
  villa     Villa            @relation(fields: [villaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([villaId, checkIn, checkOut])
  @@index([propertySlug, checkIn, checkOut])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([guestEmail])
}

model BookingActivityLog {
  id        String @id @default(cuid())
  villaId   String
  bookingId String?
  actorId   String?

  type     BookingActivityType
  message  String
  metadata Json?

  villa   Villa         @relation(fields: [villaId], references: [id], onDelete: Cascade)
  booking VillaBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor   User?         @relation(fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([villaId, createdAt])
  @@index([bookingId, createdAt])
  @@index([actorId, createdAt])
  @@index([type, createdAt])
}

model VillaBlockedDate {
  id           String   @id @default(cuid())
  villaId      String
  propertySlug String   @default("sandy-toes")
  date         DateTime @db.Date
  reason       String?
  createdById  String?

  villa Villa @relation(fields: [villaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([villaId, date])
  @@unique([propertySlug, date])
  @@index([villaId, date])
  @@index([propertySlug, date])
}

model VillaPayment {
  id        String @id @default(cuid())
  bookingId String
  villaId   String

  provider          String // e.g. STRIPE, RAZORPAY, MANUAL
  providerPaymentId String?
  providerOrderId   String?
  method            String?

  amountCents Int
  currency    String        @default("USD")
  status      PaymentStatus @default(INITIALIZED)

  paidAt              DateTime?
  failedAt            DateTime?
  refundedAt          DateTime?
  refundProviderRef   String?
  recordedByAdminId   String?
  providerRawResponse Json?

  booking VillaBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  villa   Villa        @relation(fields: [villaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([villaId, createdAt])
  @@index([bookingId, createdAt])
  @@index([status, createdAt])
  @@index([providerPaymentId])
}

model VillaAdminNote {
  id        String  @id @default(cuid())
  bookingId String
  villaId   String
  adminId   String?
  note      String

  booking VillaBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  villa   Villa        @relation(fields: [villaId], references: [id])
  admin   User?        @relation(fields: [adminId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId, createdAt])
  @@index([villaId, createdAt])
  @@index([adminId])
}

model VillaEmailLog {
  id        String @id @default(cuid())
  bookingId String
  villaId   String

  recipient         String
  subject           String
  template          String
  status            EmailDeliveryStatus @default(PENDING)
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?

  booking VillaBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  villa   Villa        @relation(fields: [villaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId, createdAt])
  @@index([villaId, createdAt])
  @@index([status, createdAt])
  @@index([recipient])
}

model AppSetting {
  key   String @id
  value String
}

enum VillaBookingStatus {
  READY_FOR_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
  NO_SHOW
}

enum VillaBookingLockStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

enum VillaDamageOption {
  PROTECTION
  DEPOSIT
}

enum VillaBlockType {
  OWNER_STAY
  MAINTENANCE
  MANUAL_BLOCK
  PRIVATE_HOLD
}

enum VillaBlockSource {
  ADMIN
  OWNER
  OTA
  SYSTEM
}

enum BookingActivityType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  DATES_RESCHEDULED
  BLOCK_CREATED
  BLOCK_REMOVED
  LOCK_RELEASED
  ADMIN_NOTE_ADDED
  NO_SHOW_MARKED
  REFUND_MARKED
}

enum PaymentStatus {
  INITIALIZED
  AWAITING_PAYMENT
  PAID
  FAILED
  CANCELLED
  EXPIRED
  OFFLINE
  REFUNDED
  PARTIALLY_REFUNDED
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

